    <script>
    async function buildSectionsGrid() {
        const grid = document.getElementById('sections-grid');
        if (!grid) return;
        try {
            const data = await loadCourseStructure('../../../');
            const chapter = data.chapters.find(c => c.id === 'chapter-4');
            if (!chapter) { grid.innerHTML = '<p style="color:var(--text-secondary)">Глава не найдена.</p>'; return; }
            const paragraphs = chapter.paragraphs || [];
            if (!paragraphs.length) { grid.innerHTML = '<p style="color:var(--text-secondary)">Параграфы не найдены.</p>'; return; }

            grid.innerHTML = paragraphs.map((p, i) => {
                const href = `${p.id}.html`;
                const testCount = (p.tests || []).length;
                const testBadge = testCount > 0
                    ? `<span style="position:absolute;top:50%;right:2.5rem;transform:translateY(-50%);background:rgba(167,139,250,.15);border:1px solid rgba(167,139,250,.3);color:#a78bfa;font-size:.72rem;font-weight:700;padding:3px 10px;border-radius:99px;">${testCount > 1 ? testCount + ' теста' : 'Тест'}</span>`
                    : '';
                return `<a href="${href}" class="section-card">
                    <div class="section-card__number">§4.${i + 1}</div>
                    <div class="section-card__body"><div class="section-card__title">${p.title}</div></div>
                    ${testBadge}
                    <span class="section-card__arrow">&rsaquo;</span>
                </a>`;
            }).join('');
        } catch (e) {
            document.getElementById('sections-grid').innerHTML = '<p style="color:var(--text-secondary)">Не удалось загрузить секции: ' + e.message + '</p>';
        }
    }
    buildSectionsGrid();
    </script>

